PORT=3000
HOST=0.0.0.0
NODE_ENV=development
ENABLE_HTTPS=true
SSL_CERT=./localhost.pem
SSL_KEY=./localhost-key.pem
CORS_ORIGIN=*

# Notes:
# - ENABLE_HTTPS/SSL_CERT/SSL_KEY are only used when NODE_ENV=development.
#   In production, TLS termination happens at the hosting layer.
# - Generate local certs with mkcert, e.g.:
#     mkcert localhost 192.168.1.8
#   then point SSL_CERT/SSL_KEY at the generated files (mkcert names them
#   "localhost+1.pem" / "localhost+1-key.pem" when given multiple hosts).
# - CORS_ORIGIN accepts "*" or a comma-separated allowlist, e.g.:
#     CORS_ORIGIN=http://localhost:3000,https://ar.example.com
