PORT=3000
HOST=0.0.0.0
NODE_ENV=development
HTTPS_KEY_PATH=./localhost-key.pem
HTTPS_CERT_PATH=./localhost.pem
CORS_ORIGIN=*

# Notes:
# - HTTPS_KEY_PATH/HTTPS_CERT_PATH are only ever consulted in development
#   (NODE_ENV != production). Leave them unset (or delete this .env
#   entirely) and the server boots on plain HTTP with zero errors — no
#   hardcoded path is assumed if they're missing.
# - In production, TLS termination is delegated to the hosting/reverse-proxy
#   layer (Cloudflare, Nginx, a PaaS edge). Node always speaks raw HTTP
#   there, regardless of these two variables.
# - Generate local certs with mkcert, e.g.:
#     mkcert localhost 192.168.1.8
#   then point HTTPS_KEY_PATH/HTTPS_CERT_PATH at the generated files (mkcert
#   names them "localhost+1-key.pem" / "localhost+1.pem" when given multiple
#   hosts).
# - CORS_ORIGIN accepts "*" or a comma-separated allowlist, e.g.:
#     CORS_ORIGIN=http://localhost:3000,https://ar.example.com
