{
  "name": "ar-prototype",
  "version": "1.0.0",
  "description": "MindAR image tracking + Rive UI prototype",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build:server": "tsc",
    "build:client": "vite build",
    "build": "tsc && vite build",
    "dev:client": "vite build --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/client/tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@rive-app/canvas": "^2.38.4",
    "express": "^5.2.1",
    "mind-ar": "1.2.5",
    "three": "0.160.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/three": "0.160.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
